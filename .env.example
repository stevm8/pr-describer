# .env.example — copy to .env and fill in your values for local dev
# Never commit .env to git!

# ── GitHub App ──────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/apps/new
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=pick-a-random-string-here

# ── Groq ─────────────────────────────────────────────────────────────────────
# Free at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe ───────────────────────────────────────────────────────────────────
# Keys at: https://dashboard.stripe.com/apikeys
# Webhook secret: https://dashboard.stripe.com/webhooks (add endpoint first)
# Price ID: https://dashboard.stripe.com/products (create $9/mo product)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ─────────────────────────────────────────────────────────────────
# Create project at: https://supabase.com
# Settings → API → Project URL and service_role key
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:8000
SECRET_KEY=dev-secret-change-in-production
